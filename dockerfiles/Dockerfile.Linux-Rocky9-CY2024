FROM rockylinux/rockylinux:9 AS openrv_base

LABEL maintainer="michimussato@etik.com"

SHELL ["/bin/bash", "-c"]

# Works with
# user `rv` (after `# Install CMake` step):
#   ENV WORKDIR="/home/rv"
#   Create and run as user rv:rv
#   RUN groupadd --gid 1001 rv
#   RUN useradd --uid 1001 --gid 1001 --create-home --home-dir ${WORKDIR} --shell /bin/bash rv
#   WORKDIR ${WORKDIR}
#   USER rv
# user `root`:
#   ENV WORKDIR="/root"
#   USER root
#   WORKDIR ${WORKDIR}
#
#   ENV WORKDIR="/rv/build"
#   USER root
#   WORKDIR ${WORKDIR}
ENV WORKDIR="/rv/build"
USER root
WORKDIR ${WORKDIR}

# static versions:
ENV NINJA_VERSION="1.12.1"

# ─────────────────────────────────────────────
# CY2024 Configuration
# ─────────────────────────────────────────────
# Set RV_VFX_PLATFORM to 2024 so that we won't be confronted with an interactive
# questionnaire from `rvcmds.sh`:
ENV RV_VFX_PLATFORM="CY2024"
ENV PYTHON_VERSION="3.11.8"
ENV QT_VERSION="6.5.3"
ENV QT_MODULES="debug_info qt3d qt5compat qtcharts qtconnectivity qtdatavis3d qtgrpc qthttpserver qtimageformats qtlanguageserver qtlocation qtlottie qtmultimedia qtnetworkauth qtpdf qtpositioning qtquick3d qtquick3dphysics qtquickeffectmaker qtquicktimeline qtremoteobjects qtscxml qtsensors qtserialbus qtserialport qtshadertools qtspeech qtvirtualkeyboard qtwaylandcompositor qtwebchannel qtwebengine qtwebsockets qtwebview"
ENV QT_ARCHIVES="icu qtbase qtdeclarative qtsvg qttools qttranslations qtwayland"

# Install tools and build dependencies
RUN dnf upgrade -y \
    && dnf install -y epel-release \
    && dnf config-manager --set-enabled crb devel \
    && dnf install -y perl-CPAN

RUN cpan FindBin
    
RUN dnf groupinstall "Development Tools" -y \
    && dnf install -y \
    alsa-lib-devel \
    autoconf \
    automake \
    avahi-compat-libdns_sd-devel \
    bison \
    bzip2-devel \
    cmake-gui \
    curl-devel \
    flex \
    gcc \
    gcc-c++ \
    git \
    libX11-devel \
    libXcomposite \
    libXcomposite-devel \
    libXcursor \
    libXcursor-devel \
    libXdamage \
    libXext-devel \
    libXi-devel \
    libXrandr \
    libXrandr-devel \
    libXrender-devel \
    libXtst \
    libXxf86vm-devel \
    libaio-devel \
    libffi-devel \
    libtool \
    libxkbcommon \
    libxkbcommon-devel \
    libxkbfile \
    mesa-libGLU \
    mesa-libGLU-devel \
    mesa-compat-libOSMesa \
    mesa-compat-libOSMesa-devel \
    meson \
    nasm \
    ncurses-devel \
    nss \
    ocl-icd \
    ocl-icd-devel \
    opencl-headers \
    openssl-devel \
    patch \
    patchelf \
    pcsc-lite \
    perl-FindBin \
    perl-IPC-Cmd \
    pulseaudio-libs \
    pulseaudio-libs-glib2 \
    qt5-qtbase-devel \
    readline-devel \
    sqlite-devel \
    systemd-devel \
    tcl-devel \
    tcsh \
    tk-devel \
    wget \
    xz-devel \
    yasm \
    zip \
    zlib-devel \
    && dnf clean all

# Disable the devel repo afterwards since dnf will warn about it
RUN dnf config-manager --set-disabled devel

# Install CMake
# Todo
#  - [x] move to /opt/cmake
# https://cmake.org/cmake/help/latest/manual/cmake-variables.7.html
ENV CMAKE_VERSION="3.31.6"
ENV CMAKE_BASE="/opt/cmake"
RUN mkdir -p ${CMAKE_BASE}
ENV PATH="${CMAKE_BASE}/bin:${PATH}"
# ENV CMAKE_HOME="${CMAKE_BASE}/cmake-$(echo $CMAKE_VERSION | cut -d. -f1,2)"
#RUN curl \
#        -L https://github.com/Kitware/CMake/releases/download/v${CMAKE_VERSION}/cmake-${CMAKE_VERSION}-linux-x86_64.tar.gz \
#        -o cmake-${CMAKE_VERSION}-linux-x86_64.tar.gz \
#    && tar --strip-components=1 -xzvf cmake-${CMAKE_VERSION}-linux-x86_64.tar.gz \
#        -C ${CMAKE_BASE} cmake-${CMAKE_VERSION}-linux-x86_64 \
#    && rm -rf cmake-${CMAKE_VERSION}-linux-x86_64.tar.gz
RUN curl \
        -L https://github.com/Kitware/CMake/releases/download/v${CMAKE_VERSION}/cmake-${CMAKE_VERSION}.tar.gz \
        -o cmake-${CMAKE_VERSION}.tar.gz \
    && tar -xzvf cmake-${CMAKE_VERSION}.tar.gz \
    && pushd cmake-${CMAKE_VERSION} \
    && ./configure --prefix=${CMAKE_BASE} \
    && make \
    && make install \
    && popd \
    && rm -rf cmake-${CMAKE_VERSION}*

