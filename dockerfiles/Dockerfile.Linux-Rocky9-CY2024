RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --no-modify-path

# Install Ninja
# Todo
#  - [x] move to /opt/ninja
ENV NINJA_HOME="/opt/ninja"
RUN mkdir -p ${NINJA_HOME}
ENV PATH="${NINJA_HOME}:${PATH}"
RUN curl \
        -L https://github.com/ninja-build/ninja/releases/download/v${NINJA_VERSION}/ninja-linux.zip \
        -o ninja-linux.zip \
    && unzip ninja-linux.zip -d "${NINJA_HOME}" \
    && rm ninja-linux.zip

# Install pyenv
# Is this a problem with user `root`?
# [openrv_base 11/16] RUN echo 'eval "$(pyenv init -)"' >> ~/.bashrc
# Todo
#  - [x] move to /opt/pyenv
ENV PIP_ROOT_USER_ACTION=ignore
ENV PYENV_ROOT="/opt/pyenv"
ENV PATH="${PYENV_ROOT}/shims:${PYENV_ROOT}/bin:${PATH}"
RUN git clone http://github.com/pyenv/pyenv.git ${PYENV_ROOT}
RUN echo 'eval "$(pyenv init -)"' >> /etc/bash.bashrc

# Python environment
RUN pyenv install ${PYTHON_VERSION}
RUN pyenv global ${PYTHON_VERSION}

RUN pip install --upgrade pip

RUN python -m pip install aqtinstall

# Install Qt
# This does not seem to cache
# Todo
#  - [x] move to /opt/Qt
ENV QT_BASE="/opt/Qt"
ENV QT_HOME="${QT_BASE}/${QT_VERSION}/gcc_64"
ENV QT_QPA_PLATFORM="offscreen"
RUN python -m aqt install-qt linux desktop ${QT_VERSION} gcc_64 -O ${QT_BASE} \
    -m ${QT_MODULES} \
    --archives ${QT_ARCHIVES}

CMD ["/bin/bash"]


